#!/bin/bash
#
# Arch-X Doctor — Diagnostic health check
#
# Usage:
#   doctor
#
# Checks system state and reports pass/fail for each component.

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

DOTDIR="$(cd "$(dirname "$0")/.." && pwd)"
PASS=0
FAIL=0
WARN=0

pass() { echo -e "  ${GREEN}✓${NC} $1"; ((PASS++)); }
fail() { echo -e "  ${RED}✗${NC} $1"; ((FAIL++)); }
warn() { echo -e "  ${YELLOW}⚠${NC} $1"; ((WARN++)); }
section() { echo -e "\n${GREEN}[$1]${NC}"; }

echo ""
echo "  ╔══════════════════════════════════════╗"
echo "  ║         Arch-X Doctor                ║"
echo "  ╚══════════════════════════════════════╝"

# ─── Display Manager ────────────────────────────────

section "Display Manager"

if systemctl is-enabled sddm &>/dev/null; then
    pass "SDDM is enabled"
else
    fail "SDDM is not enabled — run: sudo systemctl enable sddm"
fi

if systemctl is-active sddm &>/dev/null; then
    pass "SDDM is running"
else
    warn "SDDM is not running (normal if checking from TTY before first boot)"
fi

if [ -f /etc/sddm.conf.d/sddm.conf ] || grep -q "whitebyte" /etc/sddm.conf 2>/dev/null; then
    pass "SDDM config deployed"
else
    fail "SDDM config missing — run update.sh to deploy"
fi

if [ -d /usr/share/sddm/themes/whitebyte ]; then
    pass "SDDM theme deployed"
else
    fail "SDDM theme missing — run update.sh to deploy"
fi

# ─── Hyprland Session ───────────────────────────────

section "Hyprland Session"

if [ -f /usr/share/wayland-sessions/hyprland.desktop ]; then
    pass "Session file exists"
else
    fail "Session file missing at /usr/share/wayland-sessions/hyprland.desktop"
fi

if command -v hyprctl &>/dev/null; then
    pass "hyprctl available"
else
    fail "hyprctl not found — hyprland package may be broken"
fi

# Hyprland local overrides (source= will error if missing)
for f in monitors.conf gpu.conf; do
    if [ -f "$HOME/.config/hypr-local/$f" ]; then
        pass "hypr-local/$f"
    else
        fail "hypr-local/$f missing — run: mkdir -p ~/.config/hypr-local && touch ~/.config/hypr-local/$f"
    fi
done

# ─── GPU Drivers ────────────────────────────────────

section "GPU Drivers"

GPU_VENDOR=$(lspci -nn 2>/dev/null | grep -i vga)
if echo "$GPU_VENDOR" | grep -qi nvidia; then
    if pacman -Q nvidia &>/dev/null || pacman -Q nvidia-open &>/dev/null; then
        pass "NVIDIA driver installed ($(pacman -Q nvidia 2>/dev/null || pacman -Q nvidia-open 2>/dev/null))"
    else
        fail "NVIDIA GPU detected but driver not installed"
    fi
    if grep -q "nvidia_drm.modeset=1" /proc/cmdline 2>/dev/null; then
        pass "nvidia_drm.modeset=1 active in kernel"
    else
        fail "nvidia_drm.modeset=1 NOT in kernel params — Hyprland may fail to start"
        if [ -f /etc/default/grub ]; then
            if grep -q "nvidia_drm.modeset=1" /etc/default/grub; then
                warn "It's in GRUB config but not active — reboot required"
            else
                fail "Not in GRUB config — run install.sh or add manually"
            fi
        elif [ -d /boot/loader ] || [ -d /efi/loader ]; then
            fail "Add 'nvidia_drm.modeset=1' to systemd-boot entries — run install.sh to auto-fix"
        else
            fail "Add 'nvidia_drm.modeset=1' to your bootloader kernel params"
        fi
    fi
elif echo "$GPU_VENDOR" | grep -qi amd; then
    if pacman -Q vulkan-radeon &>/dev/null; then
        pass "AMD Vulkan driver installed"
    else
        fail "AMD GPU detected but vulkan-radeon not installed"
    fi
elif echo "$GPU_VENDOR" | grep -qi intel; then
    if pacman -Q vulkan-intel &>/dev/null; then
        pass "Intel Vulkan driver installed"
    else
        fail "Intel GPU detected but vulkan-intel not installed"
    fi
else
    warn "Could not detect GPU vendor: $GPU_VENDOR"
fi

# ─── Symlinks ───────────────────────────────────────

section "Config Symlinks"

for dir in hypr waybar ghostty wofi ags wlogout nvim gtk-3.0 gtk-4.0; do
    target="$HOME/.config/$dir"
    if [ -L "$target" ] && [ "$(readlink -f "$target")" = "$DOTDIR/$dir" ]; then
        pass "~/.config/$dir"
    elif [ -L "$target" ]; then
        fail "~/.config/$dir → $(readlink "$target") (wrong target, expected $DOTDIR/$dir)"
    elif [ -e "$target" ]; then
        fail "~/.config/$dir exists but is not a symlink"
    else
        fail "~/.config/$dir missing"
    fi
done

for file in .zshrc; do
    target="$HOME/$file"
    if [ -L "$target" ] && [ "$(readlink -f "$target")" = "$DOTDIR/$file" ]; then
        pass "~/$file"
    elif [ -L "$target" ]; then
        fail "~/$file → $(readlink "$target") (wrong target)"
    elif [ -e "$target" ]; then
        fail "~/$file exists but is not a symlink"
    else
        fail "~/$file missing"
    fi
done

if [ -L "$HOME/.gnupg/gpg-agent.conf" ]; then
    pass "~/.gnupg/gpg-agent.conf"
else
    fail "~/.gnupg/gpg-agent.conf not linked"
fi

# ─── Systemd Services ──────────────────────────────

section "Systemd Services"

if systemctl --user is-enabled ssh-agent.socket &>/dev/null; then
    pass "ssh-agent.socket enabled"
else
    fail "ssh-agent.socket not enabled — run: systemctl --user enable --now ssh-agent.socket"
fi

if systemctl is-enabled docker &>/dev/null; then
    pass "docker.service enabled"
else
    fail "docker.service not enabled — run: sudo systemctl enable --now docker"
fi

if groups "$USER" | grep -q docker; then
    pass "$USER in docker group"
else
    fail "$USER not in docker group — run: sudo usermod -aG docker $USER"
fi

# ─── Shell ──────────────────────────────────────────

section "Shell"

if [ "$(basename "$SHELL")" = "zsh" ]; then
    pass "Default shell is zsh"
else
    fail "Default shell is $SHELL (expected zsh) — run: chsh -s /usr/bin/zsh"
fi

if [ -f /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh ]; then
    pass "zsh-autosuggestions installed"
else
    fail "zsh-autosuggestions missing"
fi

if [ -f /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]; then
    pass "zsh-syntax-highlighting installed"
else
    fail "zsh-syntax-highlighting missing"
fi

# ─── Key Packages ───────────────────────────────────

section "Key Packages"

for pkg in hyprland waybar aylurs-gtk-shell wofi hyprlock ghostty neovim sddm wlogout iptables; do
    if pacman -Q "$pkg" &>/dev/null || yay -Q "$pkg" &>/dev/null; then
        pass "$pkg"
    else
        fail "$pkg not installed"
    fi
done

# ─── Network Namespaces ────────────────────────────

section "Network Namespaces (netns)"

if [ -x /usr/local/bin/netns-x ]; then
    pass "netns-x installed"
else
    fail "netns-x not installed — run update.sh (requires ~/Tools/netns-x)"
fi

if sysctl -n net.ipv4.ip_forward 2>/dev/null | grep -q 1; then
    pass "ip_forward enabled"
else
    warn "ip_forward disabled — netns NAT won't work. Enable: sudo sysctl -w net.ipv4.ip_forward=1"
fi

# ─── Summary ────────────────────────────────────────

echo ""
echo "  ┌──────────────────────────────────────┐"
echo -e "  │  ${GREEN}$PASS passed${NC}  ${RED}$FAIL failed${NC}  ${YELLOW}$WARN warnings${NC}"
echo "  └──────────────────────────────────────┘"
echo ""

if [ "$FAIL" -gt 0 ]; then
    echo -e "  Run ${YELLOW}./update.sh${NC} to fix most issues, or follow the hints above."
    echo ""
    exit 1
fi
