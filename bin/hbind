#!/bin/bash
#
# hbind — Hyprland keybinding manager
#
# Usage:
#   hbind list                                    List all keybindings
#   hbind list --filter <pattern>                 Filter bindings by pattern
#   hbind add <mods> <key> <dispatcher> [args]    Add a keybinding
#   hbind remove <mods> <key>                     Remove a keybinding
#   hbind edit <mods> <key> <dispatcher> [args]   Modify an existing keybinding
#
# Examples:
#   hbind list
#   hbind list --filter super
#   hbind add "SUPER" "T" "exec" "ghostty"
#   hbind add "SUPER SHIFT" "T" "exec" "alacritty"
#   hbind add "" "XF86Calculator" "exec" "ghostty -e python3"
#   hbind remove "SUPER" "T"
#   hbind edit "SUPER" "T" "exec" "kitty"
#
# Bind types:
#   --type bind     Standard (default)
#   --type binde    Repeat on hold
#
# Supports $mod variable resolution from hyprland.conf.
# Changes are written to the config file and applied immediately.

set -eo pipefail

HYPR_CONF="${HYPR_CONF:-$HOME/.config/hypr/hyprland.conf}"
DIM='\033[0;90m'
WHITE='\033[0;37m'
BOLD='\033[1m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

die()  { echo -e "${RED}error:${NC} $1" >&2; exit 1; }
warn() { echo -e "${YELLOW}warn:${NC} $1" >&2; }

# ─── Resolve config files (follow source directives) ─────

resolve_config_files() {
    local files=("$HYPR_CONF")
    local sources
    sources=$(grep -h '^\s*source\s*=' "$HYPR_CONF" 2>/dev/null | sed 's/^\s*source\s*=\s*//' | sed "s|~|$HOME|g" | sed 's/\s*$//')
    while IFS= read -r f; do
        [ -n "$f" ] && [ -f "$f" ] && files+=("$f")
    done <<< "$sources"
    printf '%s\n' "${files[@]}"
}

# ─── Resolve $mod variable ───────────────────────────────

resolve_mod() {
    local mod_val
    mod_val=$(grep -h '^\$mod\s*=' "$HYPR_CONF" 2>/dev/null | head -1 | sed 's/^\$mod\s*=\s*//' | sed 's/\s*$//')
    echo "${mod_val:-SUPER}"
}

# ─── Normalize mods for comparison ───────────────────────

normalize_mods() {
    local mods="$1"
    local mod_val
    mod_val=$(resolve_mod)
    # Replace $mod with actual value
    mods="${mods//\$mod/$mod_val}"
    # Uppercase, remove extra spaces, sort modifiers
    mods=$(echo "$mods" | tr '[:lower:]' '[:upper:]' | tr -s ' ' | sed 's/^ //;s/ $//')
    echo "$mods"
}

# ─── Find which config file contains a bind ──────────────

find_bind_file() {
    local target_mods target_key
    target_mods=$(normalize_mods "$1")
    target_key=$(echo "$2" | tr '[:lower:]' '[:upper:]')

    while IFS= read -r file; do
        while IFS= read -r line; do
            local mods key
            mods=$(echo "$line" | sed -E 's/^\s*binde?\s*=\s*//' | cut -d',' -f1 | sed 's/\s*$//')
            key=$(echo "$line" | cut -d',' -f2 | sed 's/^\s*//;s/\s*$//')
            mods=$(normalize_mods "$mods")
            key=$(echo "$key" | tr '[:lower:]' '[:upper:]')
            if [ "$mods" = "$target_mods" ] && [ "$key" = "$target_key" ]; then
                echo "$file"
                return 0
            fi
        done < <(grep -E '^\s*binde?\s*=' "$file" 2>/dev/null)
    done < <(resolve_config_files)
    return 1
}

# ─── List command ─────────────────────────────────────────

cmd_list() {
    local filter=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --filter|-f) filter="$2"; shift 2 ;;
            *) filter="$1"; shift ;;
        esac
    done

    local mod_val
    mod_val=$(resolve_mod)

    while IFS= read -r file; do
        while IFS= read -r line; do
            local type mods key dispatcher args
            type=$(echo "$line" | sed -E 's/^\s*(binde?)\s*=.*/\1/')
            local rest
            rest=$(echo "$line" | sed -E 's/^\s*binde?\s*=\s*//')
            mods=$(echo "$rest" | cut -d',' -f1 | sed 's/\s*$//')
            key=$(echo "$rest" | cut -d',' -f2 | sed 's/^\s*//;s/\s*$//')
            dispatcher=$(echo "$rest" | cut -d',' -f3 | sed 's/^\s*//;s/\s*$//')
            args=$(echo "$rest" | cut -d',' -f4- | sed 's/^\s*//')

            # Resolve $mod for display
            local display_mods="${mods//\$mod/$mod_val}"

            # Build display string
            local combo
            if [ -n "$display_mods" ]; then
                combo="$display_mods + $key"
            else
                combo="$key"
            fi

            # Apply filter
            if [ -n "$filter" ]; then
                local match_str="$combo $dispatcher $args"
                if ! echo "$match_str" | grep -qi "$filter"; then
                    continue
                fi
            fi

            local type_tag=""
            [ "$type" = "binde" ] && type_tag=" ${DIM}(repeat)${NC}"

            printf "  ${BOLD}%-28s${NC} ${DIM}→${NC}  %-16s %s%b\n" "$combo" "$dispatcher" "$args" "$type_tag"
        done < <(grep -E '^\s*binde?\s*=' "$file" 2>/dev/null)
    done < <(resolve_config_files)
}

# ─── Add command ──────────────────────────────────────────

cmd_add() {
    local bind_type="bind"
    local mods="" key="" dispatcher="" args=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type|-t) bind_type="$2"; shift 2 ;;
            *)
                if [ -z "$mods" ] && [ -z "$key" ]; then
                    mods="$1"; shift
                    key="$1"; shift
                elif [ -z "$dispatcher" ]; then
                    dispatcher="$1"; shift
                else
                    if [ -n "$args" ]; then
                        args="$args $1"
                    else
                        args="$1"
                    fi
                    shift
                fi
                ;;
        esac
    done

    [ -z "$key" ] && die "usage: hbind add <mods> <key> <dispatcher> [args]"
    [ -z "$dispatcher" ] && die "missing dispatcher"

    # Check for conflicts
    local norm_mods norm_key
    norm_mods=$(normalize_mods "$mods")
    norm_key=$(echo "$key" | tr '[:lower:]' '[:upper:]')

    if find_bind_file "$mods" "$key" >/dev/null 2>&1; then
        die "$norm_mods + $norm_key is already bound. Use 'hbind edit' to modify or 'hbind remove' first."
    fi

    # Use $mod in config if mods contain the mod value
    local mod_val
    mod_val=$(resolve_mod)
    local config_mods="$mods"
    config_mods=$(echo "$config_mods" | sed "s/$mod_val/\$mod/gi")

    # Build the bind line
    local bind_line
    if [ -n "$args" ]; then
        bind_line="$bind_type = $config_mods, $key, $dispatcher, $args"
    else
        bind_line="$bind_type = $config_mods, $key, $dispatcher"
    fi

    # Append to main config (before non-bind sections)
    echo "$bind_line" >> "$HYPR_CONF"

    # Apply immediately
    local runtime_mods="${mods//\$mod/$mod_val}"
    if [ -n "$args" ]; then
        hyprctl keyword "$bind_type" "$runtime_mods,$key,$dispatcher,$args" >/dev/null 2>&1 || true
    else
        hyprctl keyword "$bind_type" "$runtime_mods,$key,$dispatcher" >/dev/null 2>&1 || true
    fi

    echo -e "  ${BOLD}added${NC}  $norm_mods + $norm_key → $dispatcher $args"
}

# ─── Remove command ───────────────────────────────────────

cmd_remove() {
    local mods="$1" key="$2"
    [ -z "$key" ] && die "usage: hbind remove <mods> <key>"

    local norm_mods norm_key
    norm_mods=$(normalize_mods "$mods")
    norm_key=$(echo "$key" | tr '[:lower:]' '[:upper:]')
    local mod_val
    mod_val=$(resolve_mod)

    local file
    file=$(find_bind_file "$mods" "$key") || die "$norm_mods + $norm_key not found"

    # Remove the line from config
    local tmp
    tmp=$(mktemp)
    while IFS= read -r line; do
        if echo "$line" | grep -qE '^\s*binde?\s*='; then
            local line_mods line_key
            line_mods=$(echo "$line" | sed -E 's/^\s*binde?\s*=\s*//' | cut -d',' -f1 | sed 's/\s*$//')
            line_key=$(echo "$line" | cut -d',' -f2 | sed 's/^\s*//;s/\s*$//')
            line_mods=$(normalize_mods "$line_mods")
            line_key=$(echo "$line_key" | tr '[:lower:]' '[:upper:]')
            if [ "$line_mods" = "$norm_mods" ] && [ "$line_key" = "$norm_key" ]; then
                continue
            fi
        fi
        echo "$line"
    done < "$file" > "$tmp"
    mv "$tmp" "$file"

    # Remove at runtime
    local runtime_mods="${mods//\$mod/$mod_val}"
    hyprctl keyword unbind "$runtime_mods,$key" >/dev/null 2>&1 || true

    echo -e "  ${BOLD}removed${NC}  $norm_mods + $norm_key"
}

# ─── Edit command ─────────────────────────────────────────

cmd_edit() {
    local mods="$1" key="$2" dispatcher="$3"
    shift 3 2>/dev/null || die "usage: hbind edit <mods> <key> <dispatcher> [args]"
    local args="$*"

    [ -z "$dispatcher" ] && die "missing dispatcher"

    local norm_mods norm_key
    norm_mods=$(normalize_mods "$mods")
    norm_key=$(echo "$key" | tr '[:lower:]' '[:upper:]')
    local mod_val
    mod_val=$(resolve_mod)

    local file
    file=$(find_bind_file "$mods" "$key") || die "$norm_mods + $norm_key not found"

    # Detect original bind type
    local orig_type="bind"

    # Use $mod in config if applicable
    local config_mods="$mods"
    config_mods=$(echo "$config_mods" | sed "s/$mod_val/\$mod/gi")

    # Build new line
    local new_line
    if [ -n "$args" ]; then
        new_line="$orig_type = $config_mods, $key, $dispatcher, $args"
    else
        new_line="$orig_type = $config_mods, $key, $dispatcher"
    fi

    # Replace in config
    local tmp
    tmp=$(mktemp)
    local replaced=0
    while IFS= read -r line; do
        if echo "$line" | grep -qE '^\s*binde?\s*='; then
            local line_mods line_key
            line_mods=$(echo "$line" | sed -E 's/^\s*binde?\s*=\s*//' | cut -d',' -f1 | sed 's/\s*$//')
            line_key=$(echo "$line" | cut -d',' -f2 | sed 's/^\s*//;s/\s*$//')
            # Capture original type
            local line_type
            line_type=$(echo "$line" | sed -E 's/^\s*(binde?)\s*=.*/\1/')
            line_mods=$(normalize_mods "$line_mods")
            line_key=$(echo "$line_key" | tr '[:lower:]' '[:upper:]')
            if [ "$line_mods" = "$norm_mods" ] && [ "$line_key" = "$norm_key" ]; then
                # Preserve original bind type
                if [ -n "$args" ]; then
                    echo "$line_type = $config_mods, $key, $dispatcher, $args"
                else
                    echo "$line_type = $config_mods, $key, $dispatcher"
                fi
                replaced=1
                continue
            fi
        fi
        echo "$line"
    done < "$file" > "$tmp"
    mv "$tmp" "$file"

    # Apply at runtime: unbind old, bind new
    local runtime_mods="${mods//\$mod/$mod_val}"
    hyprctl keyword unbind "$runtime_mods,$key" >/dev/null 2>&1 || true
    if [ -n "$args" ]; then
        hyprctl keyword bind "$runtime_mods,$key,$dispatcher,$args" >/dev/null 2>&1 || true
    else
        hyprctl keyword bind "$runtime_mods,$key,$dispatcher" >/dev/null 2>&1 || true
    fi

    echo -e "  ${BOLD}updated${NC}  $norm_mods + $norm_key → $dispatcher $args"
}

# ─── Main ─────────────────────────────────────────────────

[ ! -f "$HYPR_CONF" ] && die "config not found: $HYPR_CONF"

case "${1:-}" in
    list|ls)   shift; cmd_list "$@" ;;
    add|a)     shift; cmd_add "$@" ;;
    remove|rm) shift; cmd_remove "$@" ;;
    edit|ed)   shift; cmd_edit "$@" ;;
    ""|--help|-h)
        echo "hbind — Hyprland keybinding manager"
        echo ""
        echo "  hbind list [--filter <pattern>]              List all bindings"
        echo "  hbind add <mods> <key> <dispatcher> [args]   Add a binding"
        echo "  hbind remove <mods> <key>                    Remove a binding"
        echo "  hbind edit <mods> <key> <dispatcher> [args]  Modify a binding"
        echo ""
        echo "  Use empty string \"\" for mods when binding bare keys."
        echo "  Use --type binde for repeat-on-hold bindings."
        echo ""
        echo "Examples:"
        echo "  hbind list"
        echo "  hbind list exec"
        echo "  hbind add \"SUPER\" \"T\" \"exec\" \"ghostty\""
        echo "  hbind add \"\" \"XF86Calculator\" \"exec\" \"python3\""
        echo "  hbind remove \"SUPER\" \"T\""
        echo "  hbind edit \"SUPER\" \"T\" \"exec\" \"kitty\""
        ;;
    *)
        die "unknown command: $1 (try: list, add, remove, edit)"
        ;;
esac
