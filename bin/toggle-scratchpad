#!/bin/bash
# Toggle a scratchpad terminal using Hyprland special workspaces

SCRATCHPAD_CLASS="com.scratchpad.terminal"

if hyprctl clients -j | jq -e ".[] | select(.class == \"$SCRATCHPAD_CLASS\")" >/dev/null 2>&1; then
    hyprctl dispatch togglespecialworkspace scratchpad
else
    hyprctl dispatch exec "[workspace special:scratchpad] ghostty --class=$SCRATCHPAD_CLASS"
    sleep 0.3
    hyprctl dispatch togglespecialworkspace scratchpad
fi
