[global]
    follow = mouse

    width = (300, 500)
    height = (0, 400)
    origin = top-right
    offset = (10, 45)

    font = JetBrainsMono Nerd Font 9
    markup = full
    format = "<b>%s</b>\n%b"

    alignment = left
    vertical_alignment = center
    word_wrap = yes
    ellipsize = end

    separator_height = 1
    separator_color = frame
    padding = 12
    horizontal_padding = 14
    text_icon_padding = 10

    frame_width = 1
    frame_color = "#1a1a1a"
    corner_radius = 4
    transparency = 25

    icon_position = off

    notification_limit = 5
    indicate_hidden = yes

    mouse_left_click = do_action, open_url
    mouse_middle_click = close_all
    mouse_right_click = close_current

[urgency_low]
    background = "#0a0a0a"
    foreground = "#808080"
    frame_color = "#1a1a1a"
    timeout = 8

[urgency_normal]
    background = "#0a0a0a"
    foreground = "#e0e0e0"
    frame_color = "#2a2a2a"
    timeout = 12

[urgency_critical]
    background = "#0a0a0a"
    foreground = "#e0e0e0"
    frame_color = "#f38ba8"
    timeout = 0