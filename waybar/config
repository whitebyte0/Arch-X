{

    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 4,

    "modules-left": ["hyprland/workspaces", "hyprland/taskbar"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "custom/recording", "hyprland/language", "cpu", "memory", "temperature", "battery", "network", "pulseaudio", "custom/power"],

    "tray": {
        "icon-size": 16,
        "spacing": 8,
        "show-passive-items": true,
        "reverse-direction": false
    },

    "hyprland/workspaces": {
        "format": "{id}",
        "persistent-workspaces": {
            "*": 5
        },
        "on-click": "activate",
        "all-outputs": false
    },

    "pulseaudio": {
        "format": "σΑïΨ {volume}%",
        "format-muted": "σΑ•¹ muted",
        "format-bluetooth": "σΑ²· {volume}%",
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-",
        "tooltip-format": "{desc}\n{volume}%"
    },

    "cpu": {
        "format": "σΑΜ† {usage}%",
        "interval": 2,
        "on-click": "~/.config/waybar/scripts/cpu-info.sh",
        "tooltip-format": "CPU: {usage}%\nFreq: {avg_frequency} GHz\nLoad: {load}"
    },

    "memory": {
        "format": "σΑç¦ {percentage}%",
        "interval": 2,
        "on-click": "~/.config/waybar/scripts/memory-info.sh",
        "tooltip-format": "RAM: {used:0.1f} GiB / {total:0.1f} GiB ({percentage}%)\nSwap: {swapUsed:0.1f} GiB / {swapTotal:0.1f} GiB ({swapPercentage}%)"
    },

    "temperature": {
        "format": "σΑîè {temperatureC}¬ΑC",
        "critical-threshold": 80,
        "format-critical": "σΑΗ¹ {temperatureC}¬ΑC",
        "tooltip-format": "{temperatureC}¬ΑC / {temperatureF}¬ΑF"
    },

    "network": {
        "format-wifi": "σΑΛ® {essid}",
        "format-ethernet": "σΑàÄ {ifname}",
        "format-disconnected": "σΑΛ≠ disconnected",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}\nGateway: {gwaddr}\nσΑï£ {bandwidthUpBytes}  σΑ΅ö {bandwidthDownBytes}",
        "on-click": "~/.config/waybar/scripts/network-info.sh",
        "on-click-right": "~/.config/waybar/scripts/network-details.sh",
        "interval": 2
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
        "format-charging": "σΑ²³ {capacity}%",
        "tooltip-format": "{timeTo}\n{power} W",
        "states": {
            "warning": 30,
            "critical": 15
        }
    },

    "clock": {
        "format": "σΑΞî {:%H:%M}",
        "format-alt": "σΑÉ≠ {:%A, %d %B %Y  %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "format": {
                "today": "<b><u>{}</u></b>"
            }
        }
    },

    "custom/power": {
        "format": "σΑêΞ",
        "on-click": "wlogout --layout ~/.config/wlogout/layout --css ~/.config/wlogout/style.css -b 4 -r 1",
        "tooltip": false
    },

    "custom/recording": {
        "exec": "pgrep wf-recorder > /dev/null && echo '{\"text\": \"σΑëä\", \"class\": \"active\"}' || echo '{\"text\": \"\", \"class\": \"\"}'",
        "return-type": "json",
        "interval": 2,
        "format": "{}"
    },

    "hyprland/taskbar": {
        "format": "{icon}",
        "icon-size": 16,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },

    "hyprland/language": {
        "format": "σΑ¨¨ {}",
        "format-English (US)": "EN",
        "format-Russian": "RU",
        "format-Armenian (phonetic)": "AM"
    }
}
