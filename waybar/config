{

    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 4,

    "modules-left": ["hyprland/workspaces", "hyprland/taskbar"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "custom/recording", "hyprland/language", "cpu", "memory", "temperature", "battery", "network", "pulseaudio", "custom/power"],

    "tray": {
        "icon-size": 16,
        "spacing": 8,
        "show-passive-items": true,
        "reverse-direction": false
    },

    "hyprland/workspaces": {
        "format": "{id}",
        "persistent-workspaces": {
            "*": 5
        },
        "on-click": "activate",
        "all-outputs": false
    },

    "pulseaudio": {
        "format": "蟀暰 {volume}%",
        "format-muted": "蟀杹 muted",
        "format-bluetooth": "蟀偗 {volume}%",
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-",
        "tooltip-format": "{desc}\n{volume}%"
    },

    "cpu": {
        "format": "蟀粻 {usage}%",
        "interval": 2,
        "on-click": "~/.config/waybar/scripts/cpu-info.sh",
        "tooltip-format": "CPU: {usage}%\nFreq: {avg_frequency} GHz\nLoad: {load}"
    },

    "memory": {
        "format": "蟀崨 {percentage}%",
        "interval": 2,
        "on-click": "~/.config/waybar/scripts/memory-info.sh",
        "tooltip-format": "RAM: {used:0.1f} GiB / {total:0.1f} GiB ({percentage}%)\nSwap: {swapUsed:0.1f} GiB / {swapTotal:0.1f} GiB ({swapPercentage}%)"
    },

    "temperature": {
        "format": "蟀攺 {temperatureC}掳C",
        "critical-threshold": 80,
        "format-critical": "蟀竵 {temperatureC}掳C",
        "tooltip-format": "{temperatureC}掳C / {temperatureF}掳F"
    },

    "network": {
        "format-wifi": "蟀え {essid}",
        "format-ethernet": "蟀垁 {ifname}",
        "format-disconnected": "蟀き disconnected",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}\nGateway: {gwaddr}\n蟀晵 {bandwidthUpBytes}  蟀嚉 {bandwidthDownBytes}",
        "on-click": "~/.config/waybar/scripts/network-info.sh",
        "on-click-right": "~/.config/waybar/scripts/network-details.sh",
        "interval": 2
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["蟀伜", "蟀伝", "蟀伡", "蟀伣", "蟀伨", "蟀伩", "蟀個", "蟀倎", "蟀倐", "蟀伖"],
        "format-charging": "蟀倓 {capacity}%",
        "tooltip-format": "{timeTo}\n{power} W",
        "states": {
            "warning": 30,
            "critical": 15
        }
    },

    "clock": {
        "format": "蟀 {:%H:%M}",
        "format-alt": "蟀儹 {:%A, %d %B %Y  %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "format": {
                "today": "<b><u>{}</u></b>"
            }
        }
    },

    "custom/power": {
        "format": "蟀惀",
        "on-click": "wlogout --layout ~/.config/wlogout/layout --css ~/.config/wlogout/style.css -b 4 -r 1",
        "tooltip": false
    },

    "custom/recording": {
        "exec": "pgrep wf-recorder > /dev/null && echo '{\"text\": \"蟀憡\", \"class\": \"active\"}' || echo '{\"text\": \"\", \"class\": \"\"}'",
        "return-type": "json",
        "interval": 2,
        "format": "{}"
    },

    "hyprland/taskbar": {
        "format": "{icon}",
        "icon-size": 16,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },

    "hyprland/language": {
        "format": "蟀寣 {shortDescription}"
    }
}
