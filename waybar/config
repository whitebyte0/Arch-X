{

    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 4,

    "modules-left": ["hyprland/workspaces", "tray", "hyprland/taskbar"],
    "modules-center": ["clock"],
    "modules-right": ["custom/recording", "hyprland/language", "cpu", "memory", "temperature", "custom/battery", "bluetooth", "network", "pulseaudio", "custom/power"],

    "tray": {
        "icon-size": 16,
        "spacing": 8,
        "show-passive-items": true,
        "reverse-direction": false
    },

    "hyprland/workspaces": {
        "format": "{id}",
        "persistent-workspaces": {
            "*": 5
        },
        "on-click": "activate",
        "all-outputs": false
    },

    "pulseaudio": {
        "format": "󰕾 {volume}%",
        "format-muted": "󰖁 muted",
        "format-bluetooth": "󰂯 {volume}%",
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-",
        "tooltip-format": "{desc}\n{volume}%"
    },

    "cpu": {
        "format": "󰻠 {usage}%",
        "interval": 2,
        "on-click": "~/.config/waybar/scripts/cpu-info.sh",
        "tooltip-format": "CPU: {usage}%\nFreq: {avg_frequency} GHz\nLoad: {load}"
    },

    "memory": {
        "format": "󰍛 {percentage}%",
        "interval": 2,
        "on-click": "~/.config/waybar/scripts/memory-info.sh",
        "tooltip-format": "RAM: {used:0.1f} GiB / {total:0.1f} GiB ({percentage}%)\nSwap: {swapUsed:0.1f} GiB / {swapTotal:0.1f} GiB ({swapPercentage}%)"
    },

    "temperature": {
        "format": "󰔏 {temperatureC}°C",
        "critical-threshold": 80,
        "format-critical": "󰸁 {temperatureC}°C",
        "tooltip-format": "{temperatureC}°C / {temperatureF}°F"
    },

    "network": {
        "format-wifi": "󰤨 {essid}",
        "format-ethernet": "󰈀 {ifname}",
        "format-disconnected": "󰤭 disconnected",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}\nGateway: {gwaddr}\n󰕒 {bandwidthUpBytes}  󰇚 {bandwidthDownBytes}",
        "on-click": "~/.config/waybar/scripts/network-info.sh",
        "on-click-right": "~/.config/waybar/scripts/network-details.sh",
        "interval": 2
    },

    "custom/battery": {
        "exec": "bash ~/.config/waybar/scripts/battery-info.sh",
        "return-type": "json",
        "interval": 5
    },

    "clock": {
        "format": "󰥔 {:%H:%M}",
        "format-alt": "󰃭 {:%A, %d %B %Y  %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "format": {
                "today": "<b><u>{}</u></b>"
            }
        }
    },

    "custom/power": {
        "format": "󰐥",
        "on-click": "wlogout --layout ~/.config/wlogout/layout --css ~/.config/wlogout/style.css -b 4 -r 1",
        "tooltip": false
    },

    "custom/recording": {
        "exec": "pgrep wf-recorder > /dev/null && echo '{\"text\": \"REC\", \"class\": \"active\"}'",
        "return-type": "json",
        "interval": 2,
        "format": "{}"
    },

    "hyprland/taskbar": {
        "format": "{icon}",
        "icon-size": 16,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },

    "bluetooth": {
        "format": "󰂯 {status}",
        "format-connected": "󰂯 {device_alias}",
        "format-connected-battery": "󰂯 {device_alias} {device_battery_percentage}%",
        "format-disabled": "󰂲",
        "format-off": "󰂲",
        "format-no-controller": "",
        "on-click": "ghostty -e bluetuith",
        "tooltip-format": "{controller_alias}\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_battery_percentage}%"
    },

    "hyprland/language": {
        "format": "󰌌 {shortDescription}"
    }
}
